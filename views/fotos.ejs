                    <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-25 rounded">
                        <h5>Cozinha Sustentável</h5>
                        <p>Receitas preparadas com amor e consciência.</p>
                    </div>
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#veganCarousel" data-bs-slide="prev"><span class="carousel-control-prev-icon"></span></button>
            <button class="carousel-control-next" type="button" data-bs-target="#veganCarousel" data-bs-slide="next"><span class="carousel-control-next-icon"></span></button>
