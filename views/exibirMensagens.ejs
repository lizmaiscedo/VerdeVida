<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>VerdeVida | Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body style="background-color: #f0f7f0;">
    <nav class="navbar navbar-dark bg-success mb-4 shadow">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">VERDE<span class="text-warning">VIDA</span></a>
            <a href="/" class="btn btn-outline-light btn-sm">Sair</a>
        </div>
    </nav>

    <div class="container">
        <h2 class="text-success fw-bold mb-4">Mensagens Recebidas</h2>
        
        <div class="table-responsive bg-white p-3 rounded shadow-sm">
            <table class="table table-hover">
                <thead class="table-success">
                    <tr>
                        <th>Cliente</th>
                        <th>E-mail</th>
                        <th>Mensagem</th>
                        <th>Data</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (mensagens.length > 0) { %>
                        <% mensagens.forEach(m => { %>
                            <tr>
                                <td class="fw-bold"><%= m.nome %></td>
                                <td><%= m.email %></td>
                                <td><%= m.mensagem %></td>
                                <td><small><%= new Date(m.data).toLocaleDateString('pt-br') %></small></td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="4" class="text-center text-muted">Nenhuma mensagem.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>
