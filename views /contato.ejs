<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>VerdeVida | Contato</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-success sticky-top">
        <div class="container"><a class="navbar-brand fw-bold" href="/">VERDE<span class="text-warning">VIDA</span></a></div>
    </nav>

    <div class="container py-5">
        <div class="row g-4">
            <div class="col-md-5">
                <div class="card border-0 shadow-sm p-4 bg-success text-white mb-4">
                    <h3>Visite-nos</h3>
                    <p>Mercado Orgânico Municipal, Box 42<br>Curitiba - PR</p>
                    <p class="mb-0"><strong>WhatsApp:</strong> (41) 98888-7777</p>
                </div>

                <div class="accordion shadow-sm" id="faq">
                    <div class="accordion-item">
                        <h2 class="accordion-header"><button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#q1">Entrega em condomínios?</button></h2>
                        <div id="q1" class="accordion-collapse collapse" data-bs-parent="#faq">
                            <div class="accordion-body">Sim, entregamos com agendamento direto na portaria.</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-7">
                <form action="/enviar" method="POST" class="card p-4 shadow-sm border-0">
                    <h3 class="mb-4 text-success fw-bold">Fale Conosco</h3>
                    <div class="mb-3"><input type="text" name="nome" class="form-control" placeholder="Nome" required></div>
                    <div class="mb-3"><input type="email" name="email" class="form-control" placeholder="E-mail" required></div>
                    <div class="mb-3"><textarea name="mensagem" class="form-control" rows="4" placeholder="Sua dúvida ou sugestão"></textarea></div>
                    <button type="submit" class="btn btn-success w-100 fw-bold">ENVIAR AGORA</button>
                </form>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
